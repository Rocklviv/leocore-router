{
  "name": "leocore/router",
  "description": "Lightweight PHP 8.2+ routing library with pattern matching, parameter extraction, middleware support, and secure dispatching.",
  "type": "library",
  "license": "MIT",
  "minimum-stability": "stable",
  "keywords": [
    "php",
    "router",
    "routing",
    "http",
    "middleware",
    "psr-4"
  ],
  "authors": [
    {
      "name": "Rocklviv",
      "email": "r.rocklviv@gmail.com"
    }
  ],
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "App\\Router\\": "src/Router/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  }
}
